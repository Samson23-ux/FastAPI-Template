from functools import lru_cache
from pydantic_settings import BaseSettings, SettingsConfigDict


use_google = cookiecutter.auth_with_google == "yes"
use_github = cookiecutter.auth_with_github == "yes"


class Settings(BaseSettings):
    model_config = SettingsConfigDict(
        env_file=".env", env_encoding="utf-8", extra="allow", case_sensitive=False
    )

    # environment
    ENVIRONMENT: str = "development"

    # api details
    API_PREFIX: str = "/api/v1"
    API_TITLE: str = "{{ cookiecutter.api_title }}"
    API_VERSION: str = "v1.0"
    API_DESCRIPTION: str = "{{ cookiecutter.api_description }}"

    # async db
    ASYNC_DB_URL: str

    # sync db
    SYNC_DB_URL: str

    # test db
    ASYNC_TEST_DB_URL: str

    # Argon2
    ARGON2_PASSWORD_PEPPER: str

    # JWT
    JWT_ALGORITHM: str = "HS256"
    ACCESS_TOKEN_EXPIRE_TIME: int = 5
    REFRESH_TOKEN_EXPIRE_TIME: int = 1
    ACCESS_TOKEN_SECRET_KEY: str
    REFRESH_TOKEN_SECRET_KEY: str

    # redis
    REDIS_URL: str

    # sentry
    SENTRY_SDK_DSN: str

    {% if use_google %}
    # google oauth
    GOOGLE_CLIENT_ID: str
    GOOGLE_OAUTH_URL: str = "https://accounts.google.com/.well-known/openid-configuration"
    GOOGLE_CLIENT_SECRET: str
    {% endif %}

    {% if use_github %}
    # github oauth
    GITHUB_USER_URL: str = "https://api.github.com/user"
    GITHUB_CLIENT_ID: str
    GITHUB_EMAIL_URL: str = "https://api.github.com/user/emails"
    GITHUB_CALLBACK_URL: str = "http://localhost:8000/api/v1/auth/github/callback"
    GITHUB_CLIENT_SECRET: str
    GITHUB_AUTHORIZE_URL: str = "https://github.com/login/oauth/authorize"
    GITHUB_ACCESS_TOKEN_URL: str = "https://github.com/login/oauth/access_token"
    {% endif %}

    {% if use_google or use_github %}
    # session middleware
    SESSION_SECRET_KEY: str
    {% endif %}

    # rabbitmq
    BROKER_URL: str

    # resend email
    API_EMAIL: str
    RESEND_API_KEY: str

    # otp
    OTP_EXPIRE_TIME: int = 15


@lru_cache(maxsize=1)
def get_settings():
    return Settings()
